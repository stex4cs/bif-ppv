RewriteEngine On

# Osnovne sigurnosne postavke
<Files ".env">
    Require all denied
</Files>

# Zaštita env/ foldera i svih .env fajlova
RedirectMatch 403 ^/bif-PPV/env/
RedirectMatch 403 /\.env$

<Files "*.log">
    Require all denied
</Files>

# CORS headers
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With"
</IfModule>

# Redirect index.html to index.php (preserve hash fragment)
RewriteCond %{THE_REQUEST} ^GET\ /([^?]*?)index\.html
RewriteRule ^(.*)index\.html$ /$1index.php [R=301,L,NE]

# Hide index.php from URL (redirect /index.php to /)
RewriteCond %{THE_REQUEST} \s/+index\.php[?\s] [NC]
RewriteRule ^index\.php$ / [R=301,L]

# Redirect .html to .php for converted pages (301 permanent)
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/%1.php -f
RewriteRule ^(.+)\.html$ /$1.php [R=301,L]

# Internal rewrite: serve .php for .html requests (borci/vesti static pages)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# Clean URLs - try .php then .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# Admin security - Force all admin access through ppv_admin.php (internal rewrite, no redirect)
RewriteRule ^admin/admin\.html$ admin/ppv_admin.php [L]
RewriteRule ^admin/?$ admin/ppv_admin.php [L]

# Dynamic sitemap.xml (serves sitemap.php with all fighters/news from JSON)
RewriteRule ^sitemap\.xml$ sitemap.php [L]